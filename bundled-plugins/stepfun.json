{
  "schema_version": "2.0",
  "source": {
    "key": "stepfun",
    "display_name": "StepFun",
    "icon_name": "stepfun",
    "permission_response_style": "claude-style"
  },
  "detection": {
    "process_names": ["stepfun", "stepfun-cli"],
    "path_patterns": ["*stepfun*"],
    "priority": 1000
  },
  "hook_installation": {
    "format": "nested",
    "config_path": "~/.stepfun/hooks.json",
    "events": [
      "PreToolUse",
      "PostToolUse",
      "UserPromptSubmit",
      "SessionStart",
      "SessionEnd",
      "Stop"
    ],
    "timeout_seconds": 10
  }
}
