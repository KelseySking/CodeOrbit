{
  "schema_version": "2.0",
  "source": {
    "key": "codebuddy",
    "display_name": "CodeBuddy",
    "icon_name": "codebuddy",
    "permission_response_style": "claude-style"
  },
  "detection": {
    "process_names": ["codebuddy", "code-buddy"],
    "path_patterns": ["*codebuddy*"],
    "priority": 1000
  },
  "hook_installation": {
    "format": "nested",
    "config_path": "~/.codebuddy/hooks.json",
    "events": [
      "PreToolUse",
      "PostToolUse",
      "UserPromptSubmit",
      "SessionStart",
      "SessionEnd",
      "Stop"
    ],
    "timeout_seconds": 10
  }
}
