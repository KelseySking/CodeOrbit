{
  "schema_version": "2.0",
  "source": {
    "key": "qwen",
    "display_name": "Qwen Code",
    "icon_name": "qwen",
    "permission_response_style": "claude-style"
  },
  "detection": {
    "process_names": ["qwen", "qwen-code"],
    "path_patterns": ["*qwen*"],
    "priority": 1000
  },
  "hook_installation": {
    "format": "nested",
    "config_path": "~/.qwen/hooks.json",
    "events": [
      "PreToolUse",
      "PostToolUse",
      "UserPromptSubmit",
      "SessionStart",
      "SessionEnd",
      "Stop"
    ],
    "timeout_seconds": 10
  }
}
