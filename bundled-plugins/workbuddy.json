{
  "schema_version": "2.0",
  "source": {
    "key": "workbuddy",
    "display_name": "WorkBuddy",
    "icon_name": "workbuddy",
    "permission_response_style": "claude-style"
  },
  "detection": {
    "process_names": ["workbuddy", "work-buddy"],
    "path_patterns": ["*workbuddy*"],
    "priority": 1000
  },
  "hook_installation": {
    "format": "nested",
    "config_path": "~/.workbuddy/hooks.json",
    "events": [
      "PreToolUse",
      "PostToolUse",
      "UserPromptSubmit",
      "SessionStart",
      "SessionEnd",
      "Stop"
    ],
    "timeout_seconds": 10
  }
}
